    <!-- Target marker -->
    <body name="target" pos="0 0 0.5" quat="1 0 0 0">
      <geom name="target_geom" type="sphere" size=".02" rgba="0 1 0 1" contype="0" conaffinity="0"/>
    </body>

    <!-- Target object box-->
    <body name="object0" pos="0.025 0.525 0.025">
      <joint name="object0:joint" type="free" damping="0.01"/>
      <geom size="0.025 0.025 0.025" type="box" condim="3" name="object0" material="UR10E_urblue"
            mass="0.2" friction="1.2 0.02 0.001"/>
      <site name="object0" pos="0 0 0" size="0.02 0.02 0.02" rgba="1 0 0 1" type="sphere"/>
    </body>
  </worldbody>


  <contact>
    <!-- UR10E internal exclusions -->
    <exclude body1="UR10E_base_link"  body2="UR10E_upper_arm_link"/>
    <!-- 2F-85 internal exclusions -->
    <exclude body1="2f85_base"        body2="left_driver"/>
    <exclude body1="2f85_base"        body2="right_driver"/>
    <exclude body1="2f85_base"        body2="left_spring_link"/>
    <exclude body1="2f85_base"        body2="right_spring_link"/>
    <exclude body1="right_coupler"    body2="right_follower"/>
    <exclude body1="left_coupler"     body2="left_follower"/>
    <!-- Prevent gripper from colliding with the flange it is bolted to -->
    <exclude body1="UR10E_flange"     body2="2f85_base"/>
  </contact>


  <tendon>
    <!--
      Force-splitting tendon: distributes actuator force equally between
      both driver joints so the equality constraint has less work to do.
    -->
    <fixed name="split">
      <joint joint="right_driver_joint" coef="0.485"/>
      <joint joint="left_driver_joint"  coef="0.485"/>
    </fixed>
  </tendon>


  <equality>
    <connect anchor="-0.0179014 -0.00651468 0.0044"
             body1="right_follower" body2="right_coupler"
             solimp="0.95 0.99 0.001" solref="0.005 1"/>
    <connect anchor="-0.0179014 -0.00651468 0.0044"
             body1="left_follower"  body2="left_coupler"
             solimp="0.95 0.99 0.001" solref="0.005 1"/>
    <joint joint1="right_driver_joint" joint2="left_driver_joint"
           polycoef="0 1 0 0 0" solimp="0.95 0.99 0.001" solref="0.005 1"/>
  </equality>


  <actuator>
    <!-- UR10E joint position actuators (indices 0-5) -->
    <general name="UR10E_pos_shoulder_pan_joint"  class="UR10E_size4"        joint="UR10E_shoulder_pan_joint"/>
    <general name="UR10E_pos_shoulder_lift_joint" class="UR10E_size4"        joint="UR10E_shoulder_lift_joint"/>
    <general name="UR10E_pos_elbow_joint"         class="UR10E_size3_limited" joint="UR10E_elbow_joint"/>
    <general name="UR10E_pos_wrist_1_joint"       class="UR10E_size2"        joint="UR10E_wrist_1_joint"/>
    <general name="UR10E_pos_wrist_2_joint"       class="UR10E_size2"        joint="UR10E_wrist_2_joint"/>
    <general name="UR10E_pos_wrist_3_joint"       class="UR10E_size2"        joint="UR10E_wrist_3_joint"/>
    <!--
      Robotiq 2F-85 gripper actuator (index 6).
      ctrl=0   -> fully open
      ctrl=255 -> fully closed
    -->
    <!--
    The general actuator below is a customized position actuator (with some damping) where
    gainprm[0] != kp.
    The reason why gainprm[0] != kp is because the control input range has to be re-scaled to
    [0, 255]. The joint range is currently set at [0, 0.9], the control range is [0, 255] and
    kp = 100. Tau = Kp * scale * control_input - Kp * error, max(Kp * scale * control_input) = 0.9,
    hence scale = 0.9 * 100 / 255, changed the range from 0 255 to 0 1
  -->
    <!--<general class="2f85" name="fingers_actuator" tendon="split"
         forcerange="-5 5" ctrlrange="0 1"
         gainprm="80.0 0 0" biasprm="0 -100 -10"/>-->
    <general class="2f85" name="fingers_actuator" tendon="split"
                forcerange="-80 80" ctrlrange="0 255"
                gainprm="0.3137255 0 0" biasprm="0 -100 -10"/>
  </actuator>


  <sensor>
    <framepos    objtype="site" objname="UR10E_TCP" name="UR10E_pos"/>
    <framequat   objtype="site" objname="UR10E_TCP" name="UR10E_ori"/>
    <framelinvel objtype="site" objname="UR10E_TCP" name="UR10E_v"/>
    <frameangvel objtype="site" objname="UR10E_TCP" name="UR10E_w"/>
    <force       site="UR10E_TCP" name="UR10E_force"  noise="0.5"/>
    <torque      site="UR10E_TCP" name="UR10E_torque" noise="0.5"/>
  </sensor>


  <!--
    qpos:  6 arm joints + left_driver + left_spring_link + right_driver + right_spring_link
           (passive coupler/follower DOF are not in qpos)
    ctrl:  6 arm position targets + 1 gripper (0 = open)
  -->
  <keyframe>
    <key name="UR10E_home"
         qpos="1.5708 -1.5708 -1.5708 0 1.5708 0  0 0 0 0 0 0 0.025 0.525 0.025 0 0 0 0"
         ctrl="1.5708 -1.5708 -1.5708 0 1.5708 0  0"/>
  </keyframe>

</mujoco>
