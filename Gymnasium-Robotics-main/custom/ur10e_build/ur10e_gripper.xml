                      </body> <!-- /2f85_base -->
                    </body> <!-- /UR10E_flange -->
                  </body> <!-- /UR10E_wrist_3_link -->
                </body> <!-- /UR10E_wrist_2_link -->
              </body> <!-- /UR10E_wrist_1_link -->
            </body> <!-- /UR10E_forearm_link -->
